/* shared/styles/theme.css */
.side-panel {
    position: fixed;
    top: 0;
    right: 0; /* Ele fica na posição final */
    width: 100%;
    height: 100%;
    background: var(--white);
    z-index: 5000;
    
    /* O SEGREDO: Ele começa empurrado para fora da tela */
    transform: translateX(100%); 
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    
    will-change: transform; /* Avisa ao celular para deixar esse movimento rápido */
    display: flex;
    flex-direction: column;
}

.side-panel.active {
    /* Ele volta para a tela suavemente */
    transform: translateX(0); 
}
