<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Nitrogênio Protocolo</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="style-base.css">
    <link rel="stylesheet" href="style-salas.css">
    <script src="https://unpkg.com/html5-qrcode"></script>
</head>
<body>

    <div id="splash-screen">
        <div class="splash-content">
            <div id="text-dao" class="splash-text">DAO</div>
            <div id="text-nitrogenio" class="splash-text">Nitrogênio</div>
            <img src="raposa.png" alt="Logo" id="splash-logo">
        </div>
    </div>

    <div id="modal-acesso" class="modal-blueprint" style="display:none;">
        <div class="painel-seguranca">
            <div class="header-seguranca"><h3>PROTOCOLO NITROGÊNIO</h3><p>SALA RESTRITA</p></div>
            <div id="display-senha" class="dots-senha"><span></span><span></span><span></span><span></span></div>
            <div class="teclado-numerico">
                <button onclick="digitar(1)">1</button><button onclick="digitar(2)">2</button><button onclick="digitar(3)">3</button>
                <button onclick="digitar(4)">4</button><button onclick="digitar(5)">5</button><button onclick="digitar(6)">6</button>
                <button onclick="digitar(7)">7</button><button onclick="digitar(8)">8</button><button onclick="digitar(9)">9</button>
                <button class="btn-cancel" onclick="cancelarAcesso()">X</button><button onclick="digitar(0)">0</button><button class="btn-back" onclick="apagarDigitado()">⌫</button>
            </div>
            <div class="status-msg" id="status-acesso">VALIDANDO IDENTIDADE...</div>
        </div>
    </div>

    <div id="home-app">
        <header class="header-app">
            <div class="logo-text">Nitrogênio</div>
            <button id="connect-trigger" class="btn-connect">CONECTAR</button>
        </header>

        <div class="balance-section">
            <div class="balance-label">Saldo em Conta</div>
            <div class="balance-main"><span class="balance-amount">0.00 BNB</span></div>
        </div>

        <div class="action-bar">
            <div class="action-container" onclick="abrirPagar()"><div class="action-item"><i class="fa-solid fa-arrow-up"></i></div><span class="action-label">pagar</span></div>
            <div class="action-container" onclick="abrirReceber()"><div class="action-item"><i class="fa-solid fa-arrow-down"></i></div><span class="action-label">receber</span></div>
            <div class="action-container"><div class="action-item"><i class="fa-solid fa-right-left"></i></div><span class="action-label">trocar</span></div>
        </div>

        <div class="carousel-wrapper">
            <div class="room-carousel">
                <div class="room-card" onclick="abrirNFT()"><img src="raposa.png" class="raposa-azul-card"><h3>NFT ALPHA</h3><p>Mintar Identidade</p></div>
                <div class="room-card" onclick="abrirPainel('comunidade')"><i class="fa-solid fa-users"></i><h3>COMUNIDADE</h3><p>Exercícios</p></div>
                <div class="room-card" onclick="abrirPainel('governo')"><i class="fa-solid fa-building-columns"></i><h3>GOVERNO</h3><p>Decisões</p></div>
                <div class="room-card" onclick="abrirPainel('cofre')"><i class="fa-solid fa-vault"></i><h3>COFRE</h3><p>Gestão</p></div>
            </div>
        </div>
    </div>

    <div id="painel-comunidade" class="painel-folha">
        <div class="barra-fechar" onclick="fecharPainel('comunidade')"><div class="indicador-puxar"></div></div>
        <div class="area-header"><h2>Comunidade</h2></div>
        <div class="conteudo-interno" id="cronometro-da-dao"></div>
    </div>

    <div id="painel-cofre" class="painel-folha">
        <div class="barra-fechar" onclick="fecharPainel('cofre')"><div class="indicador-puxar"></div></div>
        <div class="area-header"><h2>Cofre</h2></div>
        <div id="saldo-safe-real">0.0000 BNB</div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/ethers/6.7.0/ethers.umd.min.js"></script>
    <script src="motor-web3.js"></script>
    <script src="ui-logic.js"></script>
</body>
</html>
