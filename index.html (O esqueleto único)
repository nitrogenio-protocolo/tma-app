<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Nitrogênio Protocolo</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="style.css">
    <script src="https://unpkg.com/html5-qrcode"></script>
</head>
<body>

    <div id="splash-screen">
        <div class="splash-content">
            <div id="text-dao" class="splash-text">DAO</div>
            <div id="text-nitrogenio" class="splash-text">Nitrogênio</div>
            <img src="raposa.png" alt="Logo" id="splash-logo">
        </div>
    </div>

    <div id="modal-acesso" class="modal-blueprint" style="display:none;">
        <div class="painel-seguranca">
            <div class="header-seguranca">
                <div class="escudo-ouro"></div>
                <h3>PROTOCOLO NITROGÊNIO</h3>
                <p>SALA RESTRITA: IDENTIFIQUE-SE</p>
            </div>
            <div id="display-senha" class="dots-senha">
                <span></span><span></span><span></span><span></span>
            </div>
            <div class="teclado-numerico">
                <button onclick="digitar(1)">1</button>
                <button onclick="digitar(2)">2</button>
                <button onclick="digitar(3)">3</button>
                <button onclick="digitar(4)">4</button>
                <button onclick="digitar(5)">5</button>
                <button onclick="digitar(6)">6</button>
                <button onclick="digitar(7)">7</button>
                <button onclick="digitar(8)">8</button>
                <button onclick="digitar(9)">9</button>
                <button class="btn-cancel" onclick="cancelarAcesso()">X</button>
                <button onclick="digitar(0)">0</button>
                <button class="btn-back" onclick="apagarDigitado()">⌫</button>
            </div>
            <div class="status-msg" id="status-acesso">VALIDANDO NFT ALPHA...</div>
        </div>
    </div>

    <div id="modal-termos" class="modal-cortina">
        <div class="cortina-content">
            <img src="raposa.png" alt="Logo" class="raposa-topo">
            <div class="texto-termos">
                <h3>Protocolo Nitrogênio</h3>
                <p>*Este software é uma interface de governança descentralizada.</p>
                <label class="check-container">
                    <input type="checkbox" id="check-tecnico" onchange="validarTermos()"> Li e aceito os termos técnicos.
                </label>
                <label class="check-container">
                    <input type="checkbox" id="check-responsabilidade" onchange="validarTermos()"> Sou responsável por minhas transações.
                </label>
            </div>
            <div class="rodape-termos">
                <p id="msg-convite">Aguardando aceite...</p>
                <button id="btn-entrar" class="btn-pilula-termos" onclick="aceitarTermos()" disabled>ENTRAR</button>
            </div>
        </div>
    </div>

    <div id="home-app">
        <header class="header-app">
            <div class="logo-text">Nitrogênio</div>
            <button id="connect-trigger" class="btn-connect">CONECTAR</button>
        </header>

        <div class="balance-section">
            <div class="balance-label">Saldo em Conta</div>
            <div class="balance-main">
                <span class="balance-amount">0.00 BNB</span>
            </div>
        </div>

        <div class="action-bar">
            <div class="action-container" onclick="abrirPagar()">
                <div class="action-item"><i class="fa-solid fa-arrow-up"></i></div>
                <span class="action-label">pagar</span>
            </div>
            <div class="action-container" onclick="abrirReceber()">
                <div class="action-item"><i class="fa-solid fa-arrow-down"></i></div>
                <span class="action-label">receber</span>
            </div>
            <div class="action-container">
                <div class="action-item"><i class="fa-solid fa-right-left"></i></div>
                <span class="action-label">trocar</span>
            </div>
        </div>

        <div class="carousel-wrapper">
            <div class="room-carousel">
                <div class="room-card" onclick="abrirNFT()">
                    <div class="room-icon"><img src="raposa.png" class="raposa-azul-card"></div>
                    <h3>NFT ALPHA</h3>
                    <p>Mintar Identidade</p>
                </div>
                <div class="room-card" onclick="abrirPainel('comunidade')">
                    <div class="room-icon"><i class="fa-solid fa-users"></i></div>
                    <h3>COMUNIDADE</h3>
                    <p>Área de exercícios</p>
                </div>
                <div class="room-card" onclick="abrirPainel('governo')">
                    <div class="room-icon"><i class="fa-solid fa-building-columns"></i></div>
                    <h3>GOVERNO</h3>
                    <p>Decisões Coletivas</p>
                </div>
                <div class="room-card" onclick="abrirPainel('mural')">
                    <div class="room-icon"><i class="fa-solid fa-desktop"></i></div>
                    <h3>MURAL</h3>
                    <p>Avisos e Transparência</p>
                </div>
                <div class="room-card" onclick="abrirPainel('coleta')">
                    <div class="room-icon"><i class="fa-solid fa-leaf"></i></div>
                    <h3>COLETA</h3>
                    <p>Distribuição de Ativos</p>
                </div>
                <div class="room-card" onclick="abrirPainel('protocolo')">
                    <div class="room-icon"><i class="fa-solid fa-file-shield"></i></div>
                    <h3>PROTOCOLO</h3>
                    <p>Regras e Diretrizes</p>
                </div>
                <div class="room-card" onclick="abrirPainel('cofre')">
                    <div class="room-icon"><i class="fa-solid fa-vault"></i></div>
                    <h3>COFRE</h3>
                    <p>Gestão e Liquidez</p>
                </div>
            </div>
        </div>
    </div>

    <div id="area-receber" class="area-interna">
        <header class="area-header"><i class="fa-solid fa-angle-left" onclick="fecharReceber()"></i><h2>RECEBER</h2></header>
        <div class="conversion-card">
            <div class="balance-label">Valor a receber (BNB)</div>
            <div class="input-group"><input type="number" id="bnb-receber" placeholder="0.00" step="0.0001"></div>
        </div>
        <div class="grupo-botoes">
            <button class="btn-pilula btn-cancelar" onclick="fecharReceber()">CANCELAR</button>
            <button id="btn-gerar-qr" class="btn-pilula btn-acao" onclick="gerarCobranca()" disabled>GERAR QR</button>
        </div>
        <div id="qrcode-container"></div>
    </div>

    <div id="area-pagar" class="area-interna">
        <header class="area-header"><i class="fa-solid fa-angle-left" onclick="fecharPagar()"></i><h2>PAGAR</h2></header>
        <div class="conversion-card">
            <div class="balance-label">VALOR EM BNB</div>
            <div class="input-group"><input type="number" id="valor-pagar" placeholder="0.0000" step="0.0001"></div>
            <div class="balance-label">DESTINO (CARTEIRA)</div>
            <div class="address-container"><input type="text" id="wallet-address" placeholder="0x..."><i class="fas fa-qrcode" onclick="toggleScanner()"></i></div>
            <div id="reader" style="display:none;"></div>
        </div>
        <div class="grupo-botoes">
            <button class="btn-pilula btn-cancelar" onclick="fecharPagar()">CANCELAR</button>
            <button id="btn-confirmar-pagar" class="btn-pilula btn-acao" disabled>CONFIRMAR PAGAMENTO</button>
        </div>
    </div>

    <div id="area-nft" class="area-interna" style="display:none; background-color: #007AFF !important;">
        <header class="area-header" style="background: transparent; border: none;"><i class="fa-solid fa-angle-left" onclick="fecharNFT()" style="color: white;"></i></header>
        <div style="background: white; border-radius: 40px 40px 0 0; padding: 40px 25px; height: 100%;">
            <h2 style="text-align: center;">NFT ALPHA</h2>
            <p style="text-align: center; color: #666;">Identidade Digital Nitrogênio</p>
            <button onclick="iniciarMint()" class="btn-pilula btn-acao active" style="width: 100%; margin-top: 30px;">MINTAR AGORA</button>
        </div>
    </div>

    <div id="painel-comunidade" class="painel-folha">
        <div class="barra-fechar" onclick="fecharPainel('comunidade')"><div class="indicador-puxar"></div></div>
        <div class="area-header"><h2>Comunidade</h2></div>
        <div class="conteudo-interno" id="cronometro-da-dao"></div>
    </div>

    <div id="painel-governo" class="painel-folha">
        <div class="barra-fechar" onclick="fecharPainel('governo')"><div class="indicador-puxar"></div></div>
        <div class="area-header"><h2>Governo</h2></div>
        <div class="conteudo-interno"><p>Nenhuma pauta no momento.</p></div>
    </div>

    <div id="painel-cofre" class="painel-folha">
        <div class="barra-fechar" onclick="fecharPainel('cofre')"><div class="indicador-puxar"></div></div>
        <div class="area-header"><h2>Cofre</h2></div>
        <div class="conteudo-interno">
            <div id="saldo-safe-real">0.0000 BNB</div>
            <a href="https://bscscan.com/address/0x11aBd1b9c71f97ad1df8A0Dbb789f8A96B458219" target="_blank" style="color:#007AFF; font-size:12px; font-weight:bold; text-decoration:none;">AUDITAR NO BSCSCAN</a>
        </div>
    </div>

    <nav class="nav-bar">
        <div class="nav-item active" onclick="location.reload()"><i class="fa-solid fa-house"></i></div>
        <div class="nav-item" onclick="window.open('https://t.me/ProtocoloNitrogenio', '_blank')"><i class="fa-brands fa-telegram"></i></div>
        <div class="nav-item" onclick="location.href='mailto:nitrogenioprotocolo@gmail.com'"><i class="fa-solid fa-circle-question"></i></div>
    </nav>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/ethers/6.7.0/ethers.umd.min.js"></script>
    <script src="script.js?v=3.0"></script>
</body>
</html>
